	chapter.765D19CDE84B954C.title: " Dyeable Components"
	file.0000000000000001.title: " Create Aeronautics: Skybound"
	quest.00F44F4FA88A59F9.quest_desc: ["Link it to a Rope Connector with a Rope Coupling. Given rotational force, it extends or retracts the attached rope."]
	quest.00F44F4FA88A59F9.quest_subtitle: "The Rope Winch reels rope in and out."
	quest.0251560FBD2D0D1B.quest_desc: ["A redstone signal (0-15) is output per direction the stick is tilted towards. For simplicity, the joystick outputs the redstone signal on configurable redstone link frequencies. An extra button is provided for extra controllability."]
	quest.0251560FBD2D0D1B.quest_subtitle: "The Joystick allows you to control your ship along 2 axes."
	quest.03CB4B44E73A22B3.quest_desc: ["Configure a minimum and maximum range: links within the minimum read at full strength, those beyond the maximum read nothing, and those in between scale with distance."]
	quest.03CB4B44E73A22B3.quest_subtitle: "The Modulating Linked Receiver senses the distance to Redstone Links."
	quest.045FBC3A653F7687.quest_desc: ["It passes rotation up to a set angle, then springs back to its start when the input stops. Redstone holds it in place, and the angle limit is configurable."]
	quest.045FBC3A653F7687.quest_subtitle: "The Torsion Spring relays rotation within an angle limit."
	quest.053FDD5AD459D89A.quest_desc: ["It attaches to the block in front of it and turns any structure with at least two sail-like blocks into a propeller. More sails mean more thrust."]
	quest.053FDD5AD459D89A.quest_subtitle: "The Propeller Bearing spins a propeller to make thrust."
	quest.05674EC2F9DCA5B9.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with pink dye to make it."]
	quest.05674EC2F9DCA5B9.quest_subtitle: "A Pink-dyed Large Tire."
	quest.05C1F9477895F68A.quest_desc: ["It behaves exactly like Levitite. Make it by holding blue dye in your offhand while crystallizing Levitite Blend."]
	quest.05C1F9477895F68A.quest_subtitle: "A Blue-dyed variant of Levitite."
	quest.066D922BF446DAC2.quest_desc: ["It converts Coral fluid into Forge Energy, outputting power from its top and bottom faces."]
	quest.066D922BF446DAC2.quest_subtitle: "The Coral Generator makes power from Coral fluid."
	quest.074A4F5C89155D9C.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with pink dye to make it."]
	quest.074A4F5C89155D9C.quest_subtitle: "A Pink-dyed Tire."
	quest.07BE6D0CE9B587AA.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with blue dye to make it."]
	quest.07BE6D0CE9B587AA.quest_subtitle: "A Blue-dyed Tire."
	quest.07CD69D9A4712343.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with orange dye to make it."]
	quest.07CD69D9A4712343.quest_subtitle: "An Orange-dyed Large Tire."
	quest.0840C62E91BAD7FE.quest_desc: ["Bind keyboard keys to Redstone Link frequencies to control many links at once. While active it takes over your movement keys and any bound keys."]
	quest.0840C62E91BAD7FE.quest_subtitle: "The Linked Typewriter binds keys to Redstone Link frequencies."
	quest.0899F1A317DE5D5C.quest_desc: ["It lets a submarine float and can be filled with water using a Ballast Vent. Its capacity can be checked with Create's Engineer's Goggles."]
	quest.0899F1A317DE5D5C.quest_subtitle: "The Ballast Tank controls a submarine's buoyancy."
	quest.08C5D49B7352385A.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with green dye to make it."]
	quest.08C5D49B7352385A.quest_subtitle: "A Green-dyed Tire."
	quest.09197DD41E190CC2.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with brown dye to make it."]
	quest.09197DD41E190CC2.quest_subtitle: "A Brown-dyed Monstrous Tire."
	quest.094E094CAF723F38.quest_desc: ["It attaches to the block in front of it and assembles glued blocks into a Simulated Contraption when powered. Rotation passes straight through it, and redstone can unlock it to spin freely."]
	quest.094E094CAF723F38.quest_subtitle: "The Swivel Bearing assembles a contraption that can spin."
	quest.0A93FEE51028A7ED.quest_desc: ["It behaves exactly like Levitite. Make it by holding orange dye in your offhand while crystallizing Levitite Blend."]
	quest.0A93FEE51028A7ED.quest_subtitle: "An Orange-dyed variant of Levitite."
	quest.0CCF10D10F894B7A.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with gray dye to make it."]
	quest.0CCF10D10F894B7A.quest_subtitle: "A Gray-dyed Large Tire."
	quest.0D701C18E51413C8.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with orange dye to make it."]
	quest.0D701C18E51413C8.quest_subtitle: "An Orange-dyed Monstrous Tire."
	quest.0D84377B8557480E.quest_desc: ["Right-click a Simulated Contraption with it to see a visual diagram of its mass, center of mass and the forces acting on it."]
	quest.0D84377B8557480E.quest_subtitle: "The Contraption Diagram reveals the forces on your craft."
	quest.0DE6BF03E14CC2B0.quest_desc: ["It uses pressurized water and kinetic energy to generate thrust. The more pressure and speed you give it, the faster you go."]
	quest.0DE6BF03E14CC2B0.quest_subtitle: "The Water Thruster pushes your submarine through the sea."
	quest.0E78B1230C3C72FF.quest_desc: ["Right-click and drag to set its redstone output precisely. A wrench inverts the signal."]
	quest.0E78B1230C3C72FF.quest_subtitle: "The Throttle Lever is a compact analog power source."
	quest.110ECA0EC95029E6.quest_desc: ["Aeroworks bundles handy control and stabilization blocks for your aircraft, such as the Gyroscope and the Joystick."]
	quest.110ECA0EC95029E6.quest_subtitle: "A collection of addons for Create Aeronautics with blocks such as the gyroscope, joystick, and more!"
	quest.128AA441B49ADCA8.quest_desc: ["A directional thruster that can also yaw and pitch to vector thrust for steering. Each side accepts a redstone signal that tilts it toward that direction."]
	quest.128AA441B49ADCA8.quest_subtitle: "The Vector Thruster can aim its thrust."
	quest.1339E01691579FC0.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with pink dye to make it."]
	quest.1339E01691579FC0.quest_subtitle: "A Pink-dyed Small Tire."
	quest.1345BAD71D0CBBEA.quest_desc: ["Supply it with water and Forge Energy (FE) to produce oxygen. It can be powered by Create: Crafts \\& Additions, New Age or Power Grid."]
	quest.1345BAD71D0CBBEA.quest_subtitle: "The Electrolyzer turns water into oxygen."
	quest.138498F781268701.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with brown dye to make it."]
	quest.138498F781268701.quest_subtitle: "A Brown-dyed Tire."
	quest.1556C1785FEBF54B.quest_desc: ["It behaves exactly like Levitite. Make it by holding gray dye in your offhand while crystallizing Levitite Blend."]
	quest.1556C1785FEBF54B.quest_subtitle: "A Gray-dyed variant of Levitite."
	quest.16EDF4808ED3BCDB.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with lime dye to make it."]
	quest.16EDF4808ED3BCDB.quest_subtitle: "A Lime-dyed Large Tire."
	quest.17E782AB29435F2A.quest_desc: ["Throw it to plant a rope anchor at a target spot, letting you string ropes across a gap. It relies on Create Simulated for its rope connections."]
	quest.17E782AB29435F2A.quest_subtitle: "Throw a rope anchor to a distant point."
	quest.18594A0013B696D4.quest_desc: ["It outputs a redstone signal based on orientation, emitted downhill by default. Each axis works independently, and the angle of maximum signal is configurable."]
	quest.18594A0013B696D4.quest_subtitle: "The Gimbal Sensor reads your craft's tilt."
	quest.1978F486110CBC58.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with cyan dye to make it."]
	quest.1978F486110CBC58.quest_subtitle: "A Cyan-dyed Large Tire."
	quest.1A3C7EB8A16B244C.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with red dye to make it."]
	quest.1A3C7EB8A16B244C.quest_subtitle: "A Red-dyed Monstrous Tire."
	quest.1AE7D3151046ACB2.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with orange dye to make it."]
	quest.1AE7D3151046ACB2.quest_subtitle: "An Orange-dyed Small Tire."
	quest.1CC06C4B4C26D8EB.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with red dye to make it."]
	quest.1CC06C4B4C26D8EB.quest_subtitle: "A Red-dyed Tire."
	quest.1F6F077E5A84C184.quest_desc: ["It behaves exactly like Levitite. Make it by holding light blue dye in your offhand while crystallizing Levitite Blend."]
	quest.1F6F077E5A84C184.quest_subtitle: "A Light Blue-dyed variant of Levitite."
	quest.1FEFD4A091122E0C.quest_desc: ["Spin them with rotational force to produce FE for blocks like the Calibrated Thruster - the faster the RPM, the more FE they make. The Industrial Generator is the higher-output version."]
	quest.1FEFD4A091122E0C.quest_subtitle: "Generators turn rotation into Forge Energy."
	quest.2098CA328801A7A3.quest_desc: ["Holds a captured physical craft so you can carry it and print it back into the world later."]
	quest.2098CA328801A7A3.quest_subtitle: "The Portable Structure Container stores a craft as a portable blueprint."
	quest.20E81D9330FA1564.quest_desc: ["These blocks let your Simulated Contraption sense the world and respond to your commands - sensors, transmissions and control inputs."]
	quest.20E81D9330FA1564.title: "Navigation"
	quest.21C1B82822A265E6.quest_desc: ["Give it a redstone signal to release oxygen produced by an Electrolyzer. It consumes more oxygen the larger the submarine is."]
	quest.21C1B82822A265E6.quest_subtitle: "The Oxygen Diffuser keeps the inside of your submarine breathable."
	quest.22B2AE9DDBBC5079.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with purple dye to make it."]
	quest.22B2AE9DDBBC5079.quest_subtitle: "A Purple-dyed Small Tire."
	quest.23C4D2DA6DEB2D9A.quest_desc: ["It behaves exactly like Levitite. Make it by holding lime dye in your offhand while crystallizing Levitite Blend."]
	quest.23C4D2DA6DEB2D9A.quest_subtitle: "A Lime-dyed variant of Levitite."
	quest.251A6CA0F0E72812.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with white dye to make it."]
	quest.251A6CA0F0E72812.quest_subtitle: "A White-dyed Small Tire."
	quest.251ED9DA3DE04C84.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with black dye to make it."]
	quest.251ED9DA3DE04C84.quest_subtitle: "A Black-dyed Monstrous Tire."
	quest.25B581A958F22442.quest_desc: ["It emits redstone when its beam hits a block, with strength based on distance. Apply a filter so only matching blocks trigger it."]
	quest.25B581A958F22442.quest_subtitle: "The Optical Sensor detects blocks in front of it."
	quest.27CF01E530CC4280.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with cyan dye to make it."]
	quest.27CF01E530CC4280.quest_subtitle: "A Cyan-dyed Tire."
	quest.291911E6EC50FEFC.quest_desc: ["A magnetic field gun used to grab, move and reposition Aeronautics physical structures."]
	quest.291911E6EC50FEFC.quest_subtitle: "The Magnetic Gun manipulates physical craft from a distance."
	quest.2A16B58B805EAA44.quest_desc: ["Place it with a shaft above spinning at least 30 RPM and a Navigation Table below. Insert a Navigation Compass and it outputs a redstone signal based on the distance to the target, while passing the compass down to the table."]
	quest.2A16B58B805EAA44.quest_subtitle: "The Navigation Tracker reads how far you are from a target."
	quest.2C00F0070ACC0D49.quest_desc: ["It works like a Copper Fluid Tank, but holds double the fluid per block."]
	quest.2C00F0070ACC0D49.quest_subtitle: "The Platinum Fluid Tank stores fluids in bulk."
	quest.2C224C8A4945C10E.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with yellow dye to make it."]
	quest.2C224C8A4945C10E.quest_subtitle: "A Yellow-dyed Small Tire."
	quest.2C50E0D12250E1A5.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with light blue dye to make it."]
	quest.2C50E0D12250E1A5.quest_subtitle: "A Light Blue-dyed Monstrous Tire."
	quest.2C51DD06F3E9AA06.quest_desc: ["Create Deep Seas (also known as Create Submarine) expands on the systems of Create and the Sable physics engine to enable players to build, pilot, and survive in fully functional, physics-based submarines."]
	quest.2C51DD06F3E9AA06.quest_subtitle: "Submarine in Create Aeronautics!"
	quest.2CF12EE122D19969.quest_desc: ["It receives nearby Redstone Links most strongly when they are directly in front; a shallower angle gives a weaker signal, and links behind it are ignored."]
	quest.2CF12EE122D19969.quest_subtitle: "The Directional Linked Receiver senses the angle to Redstone Links."
	quest.2D6FF740F5A6A951.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with red dye to make it."]
	quest.2D6FF740F5A6A951.quest_subtitle: "A Red-dyed Small Tire."
	quest.2D70F503EA6F2994.quest_desc: ["Mount them on a Propeller Bearing to generate thrust. Wooden and Andesite Propellers are the basic, craftable options."]
	quest.2D70F503EA6F2994.quest_subtitle: "Propellers are the blades that catch the air for thrust."
	quest.2EEBDC974094D856.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with light blue dye to make it."]
	quest.2EEBDC974094D856.quest_subtitle: "A Light Blue-dyed Small Tire."
	quest.2F7C30CFCD7A1215.quest_desc: ["A powered Laser Pointer emits a beam, and a Laser Sensor detects it and outputs redstone. Apply a filter so only matching colors trigger it."]
	quest.2F7C30CFCD7A1215.quest_subtitle: "Laser Pointers and Sensors send signals across a beam."
	quest.30AE6897560E6C83.quest_desc: ["On a moving contraption they produce drag for turning and stability, and attach to each other without glue - handy for building windmills. Right-click with dye to paint them."]
	quest.30AE6897560E6C83.quest_subtitle: "Symmetric Sails act as drag surfaces and windmill blades."
	quest.30CE22AC51635FE5.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with black dye to make it."]
	quest.30CE22AC51635FE5.quest_subtitle: "A Black-dyed Small Tire."
	quest.322ED3D5037ACE11.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with yellow dye to make it."]
	quest.322ED3D5037ACE11.quest_subtitle: "A Yellow-dyed Monstrous Tire."
	quest.326F7E4191A3B586.quest_desc: ["Right-click it onto a Wheel Mount to roll across the ground. Craft it together with a dye to make one of 16 colored variants."]
	quest.326F7E4191A3B586.quest_subtitle: "The Monstrous Tire, a monstrously large all-terrain wheel."
	quest.3308C9FB157052BF.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with white dye to make it."]
	quest.3308C9FB157052BF.quest_subtitle: "A White-dyed Monstrous Tire."
	quest.337A6F12AA7787A7.quest_desc: ["It behaves exactly like Levitite. Make it by holding white dye in your offhand while crystallizing Levitite Blend."]
	quest.337A6F12AA7787A7.quest_subtitle: "A White-dyed variant of Levitite."
	quest.33FD60BF45473C41.quest_desc: ["When enough Levitite is attached to a contraption it keeps it aloft, though it can't gain altitude alone. Hold a dye in your offhand while crystallizing Levitite Blend to make a colored variant."]
	quest.33FD60BF45473C41.quest_subtitle: "Levitite keeps Simulated Contraptions afloat."
	quest.340E8841095673AD.quest_desc: ["It provides directional thrust when powered by redstone and supplied with Forge Energy (FE)."]
	quest.340E8841095673AD.quest_subtitle: "The Ion Thruster runs on electricity instead of fuel."
	quest.345621C5B198C54D.quest_desc: ["It disguises itself as any block you apply to it, and unlike regular facades it survives Create contraption and physics ship assembly. A Directional Cover variant is also available."]
	quest.345621C5B198C54D.quest_subtitle: "The Cover is a facade that survives assembly."
	quest.369A7E3794430DC4.quest_desc: ["Right-click it onto a Wheel Mount to roll across the ground. Craft it together with a dye to make one of 16 colored variants."]
	quest.369A7E3794430DC4.quest_subtitle: "The Small Tire, the most compact all-terrain wheel."
	quest.37C182DB7AFC5A18.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with light gray dye to make it."]
	quest.37C182DB7AFC5A18.quest_subtitle: "A Light Gray-dyed Large Tire."
	quest.385C311DDF5493DD.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with cyan dye to make it."]
	quest.385C311DDF5493DD.quest_subtitle: "A Cyan-dyed Small Tire."
	quest.38EC378844976A93.quest_desc: ["While worn, kinetic components show their stress and capacity, and many blocks reveal extra data such as their contents."]
	quest.38EC378844976A93.quest_subtitle: "Aviator's Goggles add useful info to your HUD."
	quest.39E3C2D99DD35934.quest_desc: ["A lightweight copycat sail for contraptions: place it, then apply another block to copy that block's material and appearance."]
	quest.39E3C2D99DD35934.quest_subtitle: "The Copycat Wing is a sail block that borrows any look."
	quest.3B5D4F93B2DFF4CC.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with purple dye to make it."]
	quest.3B5D4F93B2DFF4CC.quest_subtitle: "A Purple-dyed Monstrous Tire."
	quest.3BEDE46A6B0D3C28.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with purple dye to make it."]
	quest.3BEDE46A6B0D3C28.quest_subtitle: "A Purple-dyed Tire."
	quest.3E26F6522B3D3E58.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with green dye to make it."]
	quest.3E26F6522B3D3E58.quest_subtitle: "A Green-dyed Monstrous Tire."
	quest.3E68A212BCC5641E.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with green dye to make it."]
	quest.3E68A212BCC5641E.quest_subtitle: "A Green-dyed Large Tire."
	quest.3EC84EB6EA2E0FDC.quest_desc: ["Right-click a tire onto a Wheel Mount to fit it. They come in Small, standard, Large and Monstrous sizes for any terrain."]
	quest.3EC84EB6EA2E0FDC.quest_subtitle: "Tires let your contraption drive across the ground."
	quest.3EE264726A5354CC.quest_desc: ["Lets you save, print and delete physical craft in survival mode - the core of the toolgun blueprint workflow."]
	quest.3EE264726A5354CC.quest_subtitle: "The Survival Structure Tool is the survival-friendly toolgun."
	quest.4058BCBC7493D7BB.quest_desc: ["A convenient alternative to Super Glue: click two points to make a glued area, then assemble. Unlike Super Glue, it only attaches to Simulated Contraptions."]
	quest.4058BCBC7493D7BB.quest_subtitle: "Honey Glue groups blocks for Simulated Contraptions."
	quest.40EFF12F6BD08A28.quest_desc: ["It behaves exactly like Levitite. Make it by holding magenta dye in your offhand while crystallizing Levitite Blend."]
	quest.40EFF12F6BD08A28.quest_subtitle: "A Magenta-dyed variant of Levitite."
	quest.40FB7ECF967AE45A.quest_desc: ["Unpowered it acts like an encased cogwheel; a redstone signal changes the gear ratio, and full signal lets the shaft and cogwheel spin independently."]
	quest.40FB7ECF967AE45A.quest_subtitle: "The Analog Transmission gears rotation with redstone."
	quest.427CB698EA6AB226.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with gray dye to make it."]
	quest.427CB698EA6AB226.quest_subtitle: "A Gray-dyed Tire."
