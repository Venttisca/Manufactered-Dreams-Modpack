	quest.4446C9E3387287A9.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with lime dye to make it."]
	quest.4446C9E3387287A9.quest_subtitle: "A Lime-dyed Tire."
	quest.445EC4706FBE3A4A.quest_desc: ["It converts an incoming redstone signal strength into a configurable redstone output signal."]
	quest.445EC4706FBE3A4A.quest_subtitle: "The Redstone Converter remaps signal strength."
	quest.4474950744B2A197.quest_desc: ["Create Aeronautics: Toolgun is an expansion mod aimed at bringing a VMod-like engineering workflow into the Create Aeronautics vehicle environment, while being specifically adapted and extended around Aeronautics physical structures."]
	quest.4474950744B2A197.quest_subtitle: "A Create Aeronautics tool expansion that adds a toolgun-style blueprint system and magnetic field guns for saving, printing, deleting, and manipulating physical craft."
	quest.4474950744B2A197.title: "Create Aeronautics: Toolgun"
	quest.449B33FFDD357065.quest_desc: ["It behaves exactly like Levitite. Make it by holding yellow dye in your offhand while crystallizing Levitite Blend."]
	quest.449B33FFDD357065.quest_subtitle: "A Yellow-dyed variant of Levitite."
	quest.45EF93C539B4689C.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with yellow dye to make it."]
	quest.45EF93C539B4689C.quest_subtitle: "A Yellow-dyed Tire."
	quest.461E3EE93322116C.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with cyan dye to make it."]
	quest.461E3EE93322116C.quest_subtitle: "A Cyan-dyed Monstrous Tire."
	quest.474804E4154F2C34.quest_desc: ["Supply it with FE from a Generator, then give it a redstone signal to fire it up. Right-click it with an Ionized Thermal Mechanism to upgrade it to soul fire for more thrust, at double the power cost."]
	quest.474804E4154F2C34.quest_subtitle: "The Calibrated Thruster pushes your craft using electrical power."
	quest.47B1FE98C581834D.quest_desc: ["Right-click it onto a Wheel Mount to roll across the ground. Craft it together with a dye to make one of 16 colored variants."]
	quest.47B1FE98C581834D.quest_subtitle: "The Tire, a standard all-terrain wheel."
	quest.488574695C845D32.quest_desc: ["It consumes valid liquid fuels to produce heat and can pass fluid through while running. It also supports redstone thermostat control."]
	quest.488574695C845D32.quest_subtitle: "The Liquid Burner makes heat from liquid fuel."
	quest.4AA6E52423B4A264.quest_desc: ["Powered magnets pull on or push away other magnets - opposite poles attract, like poles repel, and attracting magnets try to align."]
	quest.4AA6E52423B4A264.quest_subtitle: "Redstone Magnets attract and repel each other."
	quest.4AEAEBF9EC825F7B.quest_desc: ["In Direct mode the input signal maps straight to the output ratio; in Incremental mode each pulse shifts the ratio step by step."]
	quest.4AEAEBF9EC825F7B.quest_subtitle: "The Redstone Transmission gears rotation with redstone."
	quest.4C8DDA689FE8369D.quest_desc: ["Cast it into a mold and apply heat to crystallize it into solid Levitite. Once the reaction starts it spreads through the whole fluid and can't be recollected."]
	quest.4C8DDA689FE8369D.quest_subtitle: "Levitite Blend is the liquid that crystallizes into Levitite."
	quest.4C900E5C7D80C67F.quest_desc: ["Heat it from below with a Burner and it generates rotational force. Remove the heat and it winds down."]
	quest.4C900E5C7D80C67F.quest_subtitle: "The Stirling Engine turns heat into rotation."
	quest.4CD565A8B60FF798.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with magenta dye to make it."]
	quest.4CD565A8B60FF798.quest_subtitle: "A Magenta-dyed Large Tire."
	quest.4CD822763FCBF7EF.quest_desc: ["It outputs a redstone signal based on speed along its facing axis. The value box sets the speed for maximum signal, and the output side can be flipped."]
	quest.4CD822763FCBF7EF.quest_subtitle: "The Velocity Sensor reads how fast your craft is moving."
	quest.4ECDD706A12D0B55.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with black dye to make it."]
	quest.4ECDD706A12D0B55.quest_subtitle: "A Black-dyed Large Tire."
	quest.4F19053A36114341.quest_desc: ["It tilts its rotational output based on an analog redstone signal - a stronger signal on one side tilts it further that way."]
	quest.4F19053A36114341.quest_subtitle: "The Tilt Adapter angles rotation with redstone."
	quest.4FEFB2F08A61A1D6.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with brown dye to make it."]
	quest.4FEFB2F08A61A1D6.quest_subtitle: "A Brown-dyed Small Tire."
	quest.500FA9792456C013.quest_desc: ["Glue a group of blocks together with Super Glue or Honey Glue, then hold right-click and pull the lever to assemble them into a physics-driven contraption. Any assembler can disassemble it later."]
	quest.500FA9792456C013.quest_subtitle: "The Physics Assembler is the heart of every Simulated Contraption."
	quest.50581515CDE49180.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with brown dye to make it."]
	quest.50581515CDE49180.quest_subtitle: "A Brown-dyed Large Tire."
	quest.512C2F38D9309C6E.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with light gray dye to make it."]
	quest.512C2F38D9309C6E.quest_subtitle: "A Light Gray-dyed Monstrous Tire."
	quest.513D5B47A7AE1492.quest_desc: ["Right-click it onto a Wheel Mount to roll across the ground. Craft it together with a dye to make one of 16 colored variants."]
	quest.513D5B47A7AE1492.quest_subtitle: "The Large Tire, a big all-terrain wheel."
	quest.5287D9F564797135.quest_desc: ["It generates thrust when spun and automatically pitches along one axis to point up. Right-click with a wrench to reverse its thrust."]
	quest.5287D9F564797135.quest_subtitle: "The Smart Propeller pitches itself to face upward."
	quest.52A593D191365A78.quest_desc: ["Place it on a sub-level (a ship or aircraft) and use its GUI to claim the whole structure. Add more Aero-claims to cover a larger build, and set permissions for parties, allies or everyone."]
	quest.52A593D191365A78.quest_subtitle: "The Claim Block protects a sub-level from others."
	quest.55239B8751A3080F.quest_desc: ["A sturdy casing made from platinum, used to craft and encase Propulsion machinery."]
	quest.55239B8751A3080F.quest_subtitle: "Platinum Casing, Propulsion's machine casing."
	quest.55DBEABEF5174219.quest_desc: ["It adds rocket-style thrusters, wings, burners and fuel systems so you can power and steer your craft with raw thrust."]
	quest.55DBEABEF5174219.quest_subtitle: "Create Propulsion: Simulated is a NeoForge addon for Minecraft 1.21.1 that brings propulsion-focused Create gameplay to the Sable + Create Aeronautics ecosystem."
	quest.55DBEABEF5174219.title: "Create Propulsion: Simulated"
	quest.5628479EB6BB2EBF.quest_desc: ["It behaves exactly like Levitite. Make it by holding brown dye in your offhand while crystallizing Levitite Blend."]
	quest.5628479EB6BB2EBF.quest_subtitle: "A Brown-dyed variant of Levitite."
	quest.566E38B30F4AE69F.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with light blue dye to make it."]
	quest.566E38B30F4AE69F.quest_subtitle: "A Light Blue-dyed Tire."
	quest.56964EE9BF575F80.quest_desc: ["It needs rotational force and must be piped to the ballast tanks, with at least one face touching the sea. Reverse the rotation to switch to Drain Mode and push water back out."]
	quest.56964EE9BF575F80.quest_subtitle: "The Ballast Vent floods and drains your ballast tanks."
	quest.5760BF287EEB0C0E.quest_desc: ["It behaves exactly like Levitite. Make it by holding purple dye in your offhand while crystallizing Levitite Blend."]
	quest.5760BF287EEB0C0E.quest_subtitle: "A Purple-dyed variant of Levitite."
	quest.57D7693005A610F0.quest_desc: ["It burns solid fuel to heat the machine above it, such as a Stirling Engine, and supports a redstone thermostat override."]
	quest.57D7693005A610F0.quest_subtitle: "The Solid Burner makes heat from solid fuel."
	quest.58E158C8F2C04BEB.quest_desc: ["Levitite Blend crystallizes into Levitite when heated. When enough Levitite is attached to a contraption it keeps it afloat, though it can't climb on its own."]
	quest.58E158C8F2C04BEB.quest_subtitle: "Crystallize Levitite Blend into solid Levitite."
	quest.599CBC177D3D745D.quest_desc: ["Right-click a Rope Winch and a Rope Connector with it to attach them with rope. Shears remove the rope again."]
	quest.599CBC177D3D745D.quest_subtitle: "The Rope Coupling ties rope connections together."
	quest.59AB803FFC868FFC.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with black dye to make it."]
	quest.59AB803FFC868FFC.quest_subtitle: "A Black-dyed Tire."
	quest.5B50E0BA87CF1BDC.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with white dye to make it."]
	quest.5B50E0BA87CF1BDC.quest_subtitle: "A White-dyed Large Tire."
	quest.5C6E945F38EA9846.quest_desc: ["It mounts wheel-like items so your craft can roll. Power it from the top to brake, or from a side to steer toward that side."]
	quest.5C6E945F38EA9846.quest_subtitle: "The Wheel Mount holds tires for ground travel."
	quest.5CE5CD23C00E3F04.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with light blue dye to make it."]
	quest.5CE5CD23C00E3F04.quest_subtitle: "A Light Blue-dyed Large Tire."
	quest.5D745773CEA7E388.quest_desc: ["Unlike drills they break a whole area around themselves, and snap onto blocks and each other without glue. Mount them on a Borehead Bearing to dig."]
	quest.5D745773CEA7E388.quest_subtitle: "Rock Cutting Wheels carve through terrain on a Borehead Bearing."
	quest.5D851AA005725F11.quest_desc: ["Smelted from Platinum Ore, it is used to craft Propulsion's machines and casings."]
	quest.5D851AA005725F11.quest_subtitle: "Platinum Ingot, the base metal of Propulsion."
	quest.5DC411437882B19D.quest_desc: ["Mount and ride it, then left-click to fire a rope connector at a target and right-click to remove the rope. Load it with Throwable Rope Connectors as ammo."]
	quest.5DC411437882B19D.quest_subtitle: "A mounted launcher that fires rope anchors."
	quest.5DCE62E32B5099CA.quest_desc: ["It behaves exactly like Levitite. Make it by holding green dye in your offhand while crystallizing Levitite Blend."]
	quest.5DCE62E32B5099CA.quest_subtitle: "A Green-dyed variant of Levitite."
	quest.5E051237C5E852FB.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with pink dye to make it."]
	quest.5E051237C5E852FB.quest_subtitle: "A Pink-dyed Monstrous Tire."
	quest.5F76EA2FEC505EAE.quest_desc: ["It behaves exactly like Levitite. Make it by holding light gray dye in your offhand while crystallizing Levitite Blend."]
	quest.5F76EA2FEC505EAE.quest_subtitle: "A Light Gray-dyed variant of Levitite."
	quest.6073B047C7B98625.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with red dye to make it."]
	quest.6073B047C7B98625.quest_subtitle: "A Red-dyed Large Tire."
	quest.607F881A2C2B5F97.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with gray dye to make it."]
	quest.607F881A2C2B5F97.quest_subtitle: "A Gray-dyed Small Tire."
	quest.6142979F2E5E54E5.quest_desc: ["Powered by the Sable physics engine, Create Aeronautics lets you assemble real, physics-driven airships and vehicles. This chapter walks through the blocks that make them fly."]
	quest.6142979F2E5E54E5.quest_subtitle: "Build and pilot physics-based aircraft with Create Aeronautics."
	quest.6262A1BE2DF8FFA1.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with blue dye to make it."]
	quest.6262A1BE2DF8FFA1.quest_subtitle: "A Blue-dyed Small Tire."
	quest.63279EB782F2752F.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with magenta dye to make it."]
	quest.63279EB782F2752F.quest_subtitle: "A Magenta-dyed Monstrous Tire."
	quest.654FBC78D1C3B35D.quest_desc: ["It outputs a redstone signal based on elevation. Set the minimum and maximum altitude in its UI, and read exact height and air pressure with Engineer's Goggles."]
	quest.654FBC78D1C3B35D.quest_subtitle: "The Altitude Sensor reads your height and air pressure."
	quest.65715BCC3BF025C1.quest_desc: ["Power it with redstone to fill the Envelope above with hot air. The input panel sets the maximum output, and several burners can share one balloon."]
	quest.65715BCC3BF025C1.quest_subtitle: "The Hot Air Burner fills balloons with lift."
	quest.675A9530C02D7A94.quest_desc: ["Unpowered it stops relaying rotation; power the straight side to relay it, the reverse side to flip it, or both sides to stop."]
	quest.675A9530C02D7A94.quest_subtitle: "The Directional Gearshift controls rotation direction with redstone."
	quest.677DFEE3535D5FB5.quest_desc: ["Run cables to move FE around your build. Place the first set with a Cable Spool."]
	quest.677DFEE3535D5FB5.quest_subtitle: "Cables carry Forge Energy between machines."
	quest.6887C6B7ED8727B3.quest_desc: ["They enclose a volume that generates lift when filled with hot air, which must be sealed in by airtight blocks. Right-click with dye to recolor them."]
	quest.6887C6B7ED8727B3.quest_subtitle: "Envelope Blocks form the balloon that lifts your craft."
	quest.6A891A299CB4627F.quest_desc: ["Power it with redstone and feed it Turpentine through a pipe to push your craft. Its throttle scales with the redstone signal."]
	quest.6A891A299CB4627F.quest_subtitle: "The Thruster provides raw directional thrust."
	quest.6BC833A2D916A0DC.quest_desc: ["A pair extend, align and lock into a rigid connection that still keeps both sides independent. Once docked, items and fluids can pass between them."]
	quest.6BC833A2D916A0DC.quest_subtitle: "Docking Connectors lock two contraptions together."
	quest.6DE61A1D5AEE2153.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with white dye to make it."]
	quest.6DE61A1D5AEE2153.quest_subtitle: "A White-dyed Tire."
	quest.6E033C8BD4724C99.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with blue dye to make it."]
	quest.6E033C8BD4724C99.quest_subtitle: "A Blue-dyed Monstrous Tire."
	quest.6E14453ED3BE0EE0.quest_desc: ["Pump it into Thrusters to keep them firing. Hold Shift to preview thrust and burn rate."]
	quest.6E14453ED3BE0EE0.quest_subtitle: "Turpentine is the fuel that powers Thrusters."
	quest.6E1BE7174F44D650.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with light gray dye to make it."]
	quest.6E1BE7174F44D650.quest_subtitle: "A Light Gray-dyed Tire."
	quest.6EA6C44A8FBFCFD9.quest_desc: ["It behaves exactly like Levitite. Make it by holding cyan dye in your offhand while crystallizing Levitite Blend."]
	quest.6EA6C44A8FBFCFD9.quest_subtitle: "A Cyan-dyed variant of Levitite."
	quest.6FB3B725E195FEAC.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with green dye to make it."]
	quest.6FB3B725E195FEAC.quest_subtitle: "A Green-dyed Small Tire."
	quest.705C8ABB2339A5D5.quest_desc: ["Hold right-click and move the mouse to turn it, or sneak to snap to 45 degree steps. The maximum turning angle is configurable and comparators can read its position."]
	quest.705C8ABB2339A5D5.quest_subtitle: "The Steering Wheel gives precise, hands-on rotation."
	quest.7157002074776C07.quest_desc: ["Give it a Navigation Item and it emits a redstone signal toward that target, weaker when you aren't facing it directly."]
	quest.7157002074776C07.quest_subtitle: "The Navigation Table points you toward a destination."
	quest.72243D5F4B43912B.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with yellow dye to make it."]
	quest.72243D5F4B43912B.quest_subtitle: "A Yellow-dyed Large Tire."
	quest.7283D2C2EED00F55.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with gray dye to make it."]
	quest.7283D2C2EED00F55.quest_subtitle: "A Gray-dyed Monstrous Tire."
	quest.74AD9C3B54878FDB.quest_desc: ["Ideal for helicopters: it tilts the propeller to face upward and stabilize the craft. A redstone signal resets the tilt to zero."]
	quest.74AD9C3B54878FDB.quest_subtitle: "A Propeller Bearing that keeps its propeller pointing up."
	quest.74B9BA10EBDCAF89.quest_desc: ["Mount one anywhere on your contraption and supply it with rotational energy. The gyroscope stabilization scales with input RPM. Multiple gyroscopes can be used to stabilize larger ships!"]
	quest.74B9BA10EBDCAF89.quest_subtitle: "The Gyroscope is a spinning flywheel that stabilizes your ship upwards."
	quest.766261AFB8BCC811.quest_desc: ["Place Wings to shape aerodynamic surfaces. Tempered Wings are the stronger, upgraded version."]
	quest.766261AFB8BCC811.quest_subtitle: "Wings give your craft lift and control surfaces."
	quest.7758A4AE497B0696.quest_desc: ["It behaves exactly like Levitite. Make it by holding pink dye in your offhand while crystallizing Levitite Blend."]
	quest.7758A4AE497B0696.quest_subtitle: "A Pink-dyed variant of Levitite."
	quest.77EAEEB36316F1D3.quest_desc: ["It behaves exactly like Levitite. Make it by holding red dye in your offhand while crystallizing Levitite Blend."]
	quest.77EAEEB36316F1D3.quest_subtitle: "A Red-dyed variant of Levitite."
	quest.78E10AA674653EFE.quest_desc: ["This compatibility addon makes Waystones work correctly inside Sable's sub-levels, so teleporting to and from ships and plots behaves seamlessly."]
	quest.78E10AA674653EFE.quest_subtitle: "Waystones let you fast-travel, even across sub-levels."
	quest.794C0CD2DA500874.quest_desc: ["A self-contained engine that produces rotational force from fuel, in either direction. Feed it a Blaze Cake to superheat it for extra power."]
	quest.794C0CD2DA500874.quest_subtitle: "The Portable Engine generates rotation by burning fuel."
	quest.79EB7E0D64481D3E.quest_desc: ["It works exactly like the standard Small Tire - only the color changes. Craft a Small Tire together with light gray dye to make it."]
	quest.79EB7E0D64481D3E.quest_subtitle: "A Light Gray-dyed Small Tire."
	quest.7DBC2BE3FDC8A80F.quest_desc: ["It works exactly like the standard Tire - only the color changes. Craft a Tire together with orange dye to make it."]
	quest.7DBC2BE3FDC8A80F.quest_subtitle: "An Orange-dyed Tire."
	quest.7DC0802DE8DAABE4.quest_desc: ["It works exactly like the standard Monstrous Tire - only the color changes. Craft a Monstrous Tire together with lime dye to make it."]
	quest.7DC0802DE8DAABE4.quest_subtitle: "A Lime-dyed Monstrous Tire."
	quest.7E7202497F167C39.quest_desc: ["Like a steam engine it needs heat, water and boiler space. Power it with redstone to fill the balloon above, and use its panel to set the maximum output."]
	quest.7E7202497F167C39.quest_subtitle: "The Steam Vent fills balloons using steam."
	quest.7EAE26D617139AA2.quest_desc: ["It yaws and pitches like a normal Vector Thruster, but burns pumped liquid fuel instead of using FE. Pump fuel in from below and throttle with redstone."]
	quest.7EAE26D617139AA2.quest_subtitle: "A Vector Thruster that runs on liquid fuel."
	quest.7EF33147EAB0130A.quest_desc: ["It attaches to the block in front of it and assembles glued blocks into a Simulated Contraption when powered. Rotation passes straight through it, and redstone can unlock it to spin freely."]
	quest.7EF33147EAB0130A.quest_subtitle: "The Swivel Bearing assembles a contraption that can spin."
	quest.7FCD34A7D5FB6E71.quest_desc: ["It works exactly like the standard Large Tire - only the color changes. Craft a Large Tire together with purple dye to make it."]
	quest.7FCD34A7D5FB6E71.quest_subtitle: "A Purple-dyed Large Tire."
